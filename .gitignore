!project/logs/.gitkeep
!project/logs/**/final_model.zip
!project/logs/**/best_model.zip
!project/logs/**/model.zip
!project/logs/**/interrupted_model.zip
!project/logs/**/model_after_*.zip
!project/logs/**/*.pt

